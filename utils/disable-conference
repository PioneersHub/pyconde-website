#!/usr/bin/env sh
# Flip the site to INACTIVE (post-conference recap):
#  - landing page source -> content/contents.lr
#  - site_state preset   -> databags/site_state.yaml (read by the
#    archive funnel-CTA macro so "tickets on sale" retires from the
#    700 archive pages and the recap landing is the only CTA).
set -e
cp -f content/landing-page-inactive/contents.lr content/
cp -f databags/site_state.inactive.yaml databags/site_state.yaml

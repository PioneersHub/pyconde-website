#!/usr/bin/env sh
# Flip the site to ACTIVE (pre/during conference):
#  - landing page source -> content/contents.lr
#  - site_state preset   -> databags/site_state.yaml (read by the
#    archive funnel-CTA macro so "tickets on sale" appears on the
#    700 archive pages).
set -e
cp -f content/landing-page-active/contents.lr content/
cp -f databags/site_state.active.yaml databags/site_state.yaml

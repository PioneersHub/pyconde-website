<?xml version="1.0" encoding="UTF-8"?>
{#-
  /sitemap.xml is now an INDEX of segment sitemaps. Each segment file
  lists URLs of a single content kind. Easier to spot indexing problems
  per segment in Search Console, and each sub-sitemap stays under the
  50k-URL limit indefinitely.

  The /sitemaps/{kind}.xml files are real content nodes — see
  content/sitemaps/.
-#}
{%- set base = site.config.PROJECT.url -%}
<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <sitemap><loc>{{ base }}/sitemaps/pages.xml</loc></sitemap>
  <sitemap><loc>{{ base }}/sitemaps/talks-current.xml</loc></sitemap>
  <sitemap><loc>{{ base }}/sitemaps/talks-archive.xml</loc></sitemap>
  <sitemap><loc>{{ base }}/sitemaps/speakers-current.xml</loc></sitemap>
  <sitemap><loc>{{ base }}/sitemaps/speakers-archive.xml</loc></sitemap>
  <sitemap><loc>{{ base }}/sitemaps/tracks.xml</loc></sitemap>
  <sitemap><loc>{{ base }}/sitemaps/blog.xml</loc></sitemap>
</sitemapindex>
